# Balruno collab (Hocuspocus) — example env. Real values are rendered by
# Ansible into the prod-app docker-compose env file (.env), or supplied
# via .env.local for local dev.

# Postgres connection — reuses the same instance the Spring backend
# uses. The collab container talks to {@code documents.binary} only;
# all other tables stay backend-owned.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=balruno
POSTGRES_PASSWORD=
POSTGRES_DB=balruno

# Shared HS256 secret for the short-lived collab JWT (issued by Spring's
# /api/v1/auth/collab-token, verified here on every connection). MUST be
# different from the API session secret — leakage in either should not
# compromise the other.
# Generate with: openssl rand -base64 64
COLLAB_TOKEN_SECRET=

# Listening port (nginx upstream points at this; default matches the
# existing collab.balruno.com vhost).
COLLAB_PORT=1234
