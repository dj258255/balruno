{
  "name": "@balruno/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PowerBalance / balruno desktop app (Electron). Packages the packages/web build output as native Mac/Windows/Linux apps.",
  "author": {
    "name": "Balruno",
    "email": "dj258255@naver.com"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n web,electron \"npm:dev:web\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:web": "cd ../web && npm run dev",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "tsc -p tsconfig.main.json",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "lint": "echo 'desktop lint TBD'",
    "test": "echo 'desktop tests TBD'",
    "typecheck": "tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "electron-store": "^11.0.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "41.5.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.balruno.app",
    "productName": "PowerBalance",
    "copyright": "Copyright © 2026 Balruno",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "../web/.next/standalone/**/*",
      "../web/.next/static/**/*",
      "../web/public/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "dj258255",
        "repo": "balruno",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "PowerBalance ${version}",
      "icon": "build/icon.icns",
      "writeUpdateInfo": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  }
}
