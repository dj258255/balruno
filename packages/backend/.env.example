# Local-dev environment template. Copy to .env and adjust.
#
#   cp .env.example .env
#   docker compose up --build
#
# .env is gitignored. Production secrets are rendered onto prod_app by the
# Ansible backend role from group_vars/all/vault.yml — this file is for
# local development only.

# ─── Postgres (used by both the postgres container and Spring) ─────────
POSTGRES_DB=balruno_dev
POSTGRES_USER=balruno
POSTGRES_PASSWORD=dev_password_change_me

# ─── OAuth providers ───────────────────────────────────────────────────
# Same client_id / secret as production — both providers accept multiple
# callback URLs, so the http://localhost:8080/login/oauth2/code/{provider}
# callback you registered works against the same app.
#
# Leave empty to disable a provider during early development; Spring will
# skip its OAuth client registration.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
