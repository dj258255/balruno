# Balruno Web — 환경 변수 예시
# 실제 값은 .env.local 에 작성 (gitignored)

# 백엔드 REST API base URL.
# 미설정 시 로컬 모드로만 동작 (멀티유저/협업 disabled).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Y.Doc WebSocket sync endpoint.
# 보통 NEXT_PUBLIC_API_URL 와 같은 호스트의 ws/wss 엔드포인트.
# 형식: wss://api.balruno.com/ws  (백엔드 04-api-spec.md 참조)
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# 클라이언트 사이드 Sentry / 에러 추적 (선택).
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics (자동, 별도 설정 불필요).
