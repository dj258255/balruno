# Balruno Web — 환경 변수 예시
# 실제 값은 .env.local (gitignored) 또는 Vercel Dashboard 에 설정.
# 모두 NEXT_PUBLIC_* prefix 라 클라이언트 빌드에 inline 됨 (= secret 아님).

# 백엔드 REST API base URL (lib/backend/client.ts).
# Production: https://api.balruno.com
# Development: pnpm dev 띄울 때 prod 와 cross-origin 검증하려면 prod URL 사용.
# 미설정 시 default 'https://api.balruno.com' 로 fallback.
NEXT_PUBLIC_BALRUNO_API_URL=https://api.balruno.com

# 옛 lib/api 경로 호환용 (sync phase 까지 유지). 새 코드는 위 변수 사용.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Y.Doc WebSocket sync endpoint (sync phase 도착 시 사용).
# 형식: wss://collab.balruno.com/ws/...
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# 클라이언트 사이드 Sentry / 에러 추적 (선택).
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics (자동, 별도 설정 불필요).
