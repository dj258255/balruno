# Balruno Web — example environment variables.
# Set real values in .env.local (gitignored) or in the Vercel project's
# Environment Variables UI. All keys here are NEXT_PUBLIC_* and end up
# inlined into the client bundle, so they are not secrets.

# Backend REST API base URL (consumed by lib/backend/client.ts).
# Required — when unset, the client treats the backend as not configured
# and the app runs in local-only mode (sync + workspace fetch no-op).
# Production:  https://api.balruno.com
# Development: same value when smoke-testing against prod, or your own
# self-hosted backend URL.
NEXT_PUBLIC_BALRUNO_API_URL=https://api.balruno.com

# Legacy compatibility variable for the lib/api/* code path; kept until
# the sync phase migration deletes lib/api entirely. New code reads
# NEXT_PUBLIC_BALRUNO_API_URL above.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Hocuspocus collab server URL (consumed by lib/backend/collab.ts).
# Production: wss://collab.balruno.com
# The HocuspocusProvider appends the document name as the path; do NOT
# include a trailing path here.
NEXT_PUBLIC_BALRUNO_COLLAB_URL=wss://collab.balruno.com

# Legacy alias kept for the lib/api/* code path until the sync phase
# migration deletes it. New code reads NEXT_PUBLIC_BALRUNO_COLLAB_URL.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Optional client-side Sentry DSN.
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics is wired automatically; no env var needed.
