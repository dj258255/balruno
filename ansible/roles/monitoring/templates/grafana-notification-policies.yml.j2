# {{ ansible_managed }}
# Notification policy tree. Stage 0 = single root policy → Discord. Stage 1+
# split by severity (critical → Discord, warning → email digest, etc.) per
# ADR 0010 §5.

apiVersion: 1

policies:
  - orgId: 1
    receiver: discord-balruno
    group_by:
      - grafana_folder
      - alertname
    group_wait: 30s
    group_interval: 5m
    repeat_interval: 12h
    # No subroutes yet — every alert in the org goes to Discord.
