# {{ ansible_managed }}
# Prometheus scrape config — pulls node_exporter from each of the four hosts
# plus its own metrics. Targets that are unreachable (e.g. before node-exporter
# is rolled out to other hosts) are reported as `up=0` rather than failing the
# whole scrape.

global:
  scrape_interval: {{ monitoring_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_prometheus_scrape_interval }}

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node
    static_configs:
      - targets:
{% for target in monitoring_node_targets %}
          - "{{ target }}"
{% endfor %}
        labels:
          env: prod

  - job_name: loki
    static_configs:
      - targets: ["loki:3100"]

  - job_name: alloy
    static_configs:
      # Alloy runs as part of monitoring-agent on each host with Docker.
      # Post-2026-05-21 consolidation only prod_app needs it; backup
      # skips alloy to save RAM.
      - targets:
          - "{{ prod_app_private_ip }}:12345"

  - job_name: postgres
    static_configs:
      - targets: ["{{ prod_app_private_ip }}:9187"]
        labels:
          db: balruno

  # cAdvisor — per-container CPU/memory/IO. After consolidation only
  # prod_app runs the multi-container workload (Spring + Hocuspocus +
  # PG + monitoring stack), so it's the single cadvisor target.
  - job_name: cadvisor
    static_configs:
      - targets:
          - "{{ prod_app_private_ip }}:9101"
    relabel_configs:
      - source_labels: [__address__]
        regex: "{{ prod_app_private_ip }}:.*"
        target_label: host
        replacement: prod_app

  # Spring Boot Actuator — /actuator/prometheus on the *active* backend slot.
  # Blue/green deploy means port 8080 (blue) or 8081 (green) is the live one;
  # we scrape both — the inactive slot returns 0 metrics rather than failing,
  # so cardinality stays clean.
  - job_name: spring-actuator
    metrics_path: /actuator/prometheus
    static_configs:
      - targets:
          - "{{ prod_app_private_ip }}:8080"
          - "{{ prod_app_private_ip }}:8081"
        labels:
          app: balruno-backend

  # blackbox_exporter — replaces Uptime Kuma's role.
  # Prometheus instructs blackbox_exporter to probe each target via the
  # `module` query param. The 'up' metric goes 0/1 per target, plus
  # probe_duration_seconds, probe_ssl_earliest_cert_expiry, etc.
  - job_name: blackbox_http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for target in monitoring_blackbox_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "blackbox-exporter:9115"
