# {{ ansible_managed }}
# blackbox_exporter modules — defines how each probe runs.
# Prometheus drives probing via params, blackbox_exporter executes per module.

modules:
  http_2xx:
    prober: http
    timeout: 10s
    http:
      method: GET
      preferred_ip_protocol: ip4
      valid_status_codes: []        # 2xx default
      valid_http_versions: ["HTTP/1.1", "HTTP/2.0"]
      fail_if_ssl: false
      fail_if_not_ssl: false
      tls_config:
        insecure_skip_verify: false
      follow_redirects: true
      enable_http2: true
{% if vault_actuator_internal_token is defined and vault_actuator_internal_token | length > 0 %}
      # ADR 0045 — actuator gate. Sent on every http_2xx probe; targets
      # that don't enforce the token (balruno.com, monitor.balruno.com,
      # ...) simply ignore it.
      headers:
        X-Internal-Token: "{{ vault_actuator_internal_token }}"
{% endif %}

  http_401_ok:
    prober: http
    timeout: 10s
    http:
      method: GET
      valid_status_codes: [200, 401]   # 401 is fine if endpoint requires auth
      preferred_ip_protocol: ip4

  http_post_2xx:
    prober: http
    timeout: 10s
    http:
      method: POST

  tcp_connect:
    prober: tcp
    timeout: 5s

  icmp:
    prober: icmp
    timeout: 5s
    icmp:
      preferred_ip_protocol: ip4
