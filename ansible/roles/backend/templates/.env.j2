# {{ ansible_managed }}
# /opt/balruno/backend/.env — loaded by docker-compose via env_file.
#
# Mode 0600 root:root. The docker daemon (root) reads this when starting
# the backend container; rocky never needs to read the plaintext.
#
# Secrets originate in group_vars/all/vault.yml and only land here at
# Ansible-render time on prod_app. Never copied to repo.

# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_HOST={{ backend_postgres_host }}
POSTGRES_PORT={{ backend_postgres_port }}
POSTGRES_DB={{ backend_postgres_db }}
POSTGRES_USER={{ backend_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}

# ─── OAuth providers ───────────────────────────────────────────────────
GITHUB_OAUTH_CLIENT_ID={{ vault_github_oauth_client_id }}
GITHUB_OAUTH_CLIENT_SECRET={{ vault_github_oauth_client_secret }}
GOOGLE_OAUTH_CLIENT_ID={{ vault_google_oauth_client_id }}
GOOGLE_OAUTH_CLIENT_SECRET={{ vault_google_oauth_client_secret }}

# ─── JWT signing ───────────────────────────────────────────────────────
# 32-byte base64 HMAC secret per ADR 0002. Wired in B-2.3.
JWT_SECRET={{ vault_jwt_secret }}

# ─── Object storage (Phase B — StorageService + /media/*) ──────────────
# r2 = Cloudflare R2 (cloud SaaS). local = filesystem (self-host friendly
# default, no R2 account needed).
BALRUNO_STORAGE=r2
BALRUNO_R2_ENDPOINT={{ r2_endpoint }}
BALRUNO_R2_BUCKET={{ r2_media_bucket }}
BALRUNO_R2_ACCESS_KEY={{ vault_r2_media_access_key }}
BALRUNO_R2_SECRET_KEY={{ vault_r2_media_secret_key }}
