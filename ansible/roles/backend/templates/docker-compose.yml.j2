# {{ ansible_managed }}
# Production compose for the Balruno backend on prod_app.
# Image is built + pushed to GHCR by .github/workflows/backend-deploy.yml.
#
# Blue/green deploy — ADR 0044. Both colors are defined here, but each is
# gated behind a Compose profile so that `docker compose up -d` (with no
# profile) starts nothing. The deploy workflow is the only entrypoint and
# selects exactly one color via COMPOSE_PROFILES=<blue|green>.
#
# Spring listens on {{ backend_container_port }} inside both containers;
# only the host-side mapping differs. nginx routes traffic to whichever
# host port is "active" via a snippet symlink swap (see nginx role).

name: balruno-prod

services:
  backend-blue:
    profiles: [blue]
    image: {{ backend_image_repo }}:{{ backend_image_tag }}
    container_name: balruno-backend-blue
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ backend_blue_host_port }}:{{ backend_container_port }}"
    env_file:
      - {{ backend_env_file }}
    environment:
      SPRING_PROFILES_ACTIVE: "{{ backend_active_profile }}"
    # host.docker.internal resolves to the host gateway so the backend
    # can reach the Hocuspocus side-car's loopback-bound internal HTTP
    # port (127.0.0.1:{{ hocuspocus_internal_host_port }} on prod_app).
    # The side-car binds the internal endpoint to 127.0.0.1 only, so
    # this hop stays inside the host — no public surface.
    extra_hosts:
      - "host.docker.internal:host-gateway"
    mem_limit: {{ backend_mem_limit }}
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:{{ backend_container_port }}/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  backend-green:
    profiles: [green]
    image: {{ backend_image_repo }}:{{ backend_image_tag }}
    container_name: balruno-backend-green
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ backend_green_host_port }}:{{ backend_container_port }}"
    env_file:
      - {{ backend_env_file }}
    environment:
      SPRING_PROFILES_ACTIVE: "{{ backend_active_profile }}"
    # host.docker.internal resolves to the host gateway so the backend
    # can reach the Hocuspocus side-car's loopback-bound internal HTTP
    # port (127.0.0.1:{{ hocuspocus_internal_host_port }} on prod_app).
    # The side-car binds the internal endpoint to 127.0.0.1 only, so
    # this hop stays inside the host — no public surface.
    extra_hosts:
      - "host.docker.internal:host-gateway"
    mem_limit: {{ backend_mem_limit }}
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:{{ backend_container_port }}/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
