# {{ ansible_managed }}
# DATA_SOURCE_NAME drives postgres_exporter. Connects over loopback to the
# balruno DB as the application user (read-only metrics queries are safe).

DATA_SOURCE_NAME=postgresql://{{ postgres_db_user }}:{{ vault_postgres_password | urlencode }}@127.0.0.1:{{ postgres_port }}/{{ postgres_db_name }}?sslmode=disable
PG_EXPORTER_WEB_LISTEN_ADDRESS=:{{ postgres_exporter_port }}
PG_EXPORTER_AUTO_DISCOVER_DATABASES=false
