#!/usr/bin/env bash
# {{ ansible_managed }}
# Balruno PostgreSQL backup — local dump.
# Runs as the postgres user nightly via cron. Streams pg_dump | gzip into a
# dated file under {{ backup_dir }}; the object-storage-upload role's cron
# ships the newest dump to Cloudflare R2 two hours later (offsite copy).

set -euo pipefail

# cron's spawned shell may have inherited a cwd the postgres user cannot read
# (cron runs commands without changing dir to user $HOME). cd somewhere safe
# so subprocesses (find, gzip) don't blow up on getcwd().
cd /var/lib/pgsql

DUMP_DIR="{{ backup_dir }}"
DB="{{ backup_db_name }}"
TODAY="$(date -u +%Y-%m-%d)"
DUMP_FILE="$DUMP_DIR/balruno-$TODAY.sql.gz"
LOG_PREFIX="[$(date -u +%FT%TZ) balruno-backup]"

log()  { echo "$LOG_PREFIX $*"; }
fail() { log "ERROR: $*"; exit 1; }

log "starting backup for $TODAY"

mkdir -p "$DUMP_DIR"

# 1. pg_dump → gzip → file. Custom format would be richer (parallel restore)
#    but plain SQL + gzip is the simplest restore path for a small DB.
/usr/pgsql-{{ postgres_version }}/bin/pg_dump \
  --username={{ backup_db_user }} \
  --no-owner \
  --no-privileges \
  --clean --if-exists \
  "$DB" \
  | gzip -9 > "$DUMP_FILE.tmp" \
  || fail "pg_dump failed"

mv "$DUMP_FILE.tmp" "$DUMP_FILE"

# Group-readable so the balruno-backup uploader (member of the postgres
# group) can read it; nothing for world.
chmod 640 "$DUMP_FILE"

SIZE_HUMAN=$(du -h "$DUMP_FILE" | cut -f1)
log "dump done: $(basename "$DUMP_FILE") ($SIZE_HUMAN)"

# 2. Local retention — {{ backup_retention_days }}-day rolling window. R2
#    offsite keeps 30 days via bucket lifecycle; the local window is for
#    fast ad-hoc restore without an R2 round-trip.
find "$DUMP_DIR" -type f -name '*.sql.gz' -mtime +{{ backup_retention_days }} -delete

log "done"
