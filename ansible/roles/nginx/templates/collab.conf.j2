# {{ ansible_managed }}
# collab.balruno.com — Hocuspocus (yjs WebSocket) reverse proxy.
# Hocuspocus connections are long-lived (idle keepalive), so the read
# timeout is bumped from the default 60s to 1h.
#
# The upstream `balruno_collab` is defined in
# /etc/nginx/conf.d/balruno-collab-active.conf, a symlink to one of the
# blue/green snippets in /etc/nginx/snippets/. The collab-deploy workflow
# flips the symlink + nginx -s reload to graceful-cutover at deploy time
# (ADR 0044).

server {
  listen 80;
  listen [::]:80;
  server_name {{ collab_domain }};
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name {{ collab_domain }};

  ssl_certificate     {{ nginx_origin_cert_path }};
  ssl_certificate_key {{ nginx_origin_key_path }};
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers on;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:10m;

  client_max_body_size {{ nginx_client_max_body_size }};
  keepalive_timeout    {{ nginx_keepalive_timeout }};

  # Security response headers — applies to the WS upgrade handshake
  # response (101) and any HTTP error fallbacks. The Hocuspocus
  # surface is purely WebSocket so CSP / frame-ancestors stay
  # 'none', and HSTS hardens the origin direct-probe path.
  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
  add_header X-Content-Type-Options    "nosniff" always;
  add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
  add_header Permissions-Policy        "camera=(), microphone=(), geolocation=(), browsing-topics=()" always;
  add_header Content-Security-Policy   "default-src 'none'; frame-ancestors 'none'" always;

  # Reject anything not coming through Cloudflare.
  if ($http_cf_connecting_ip = "") {
    return 403;
  }

  location / {
    proxy_pass http://balruno_collab;
    proxy_http_version 1.1;

    # WS upgrade headers — Hocuspocus is purely WebSocket.
    proxy_set_header Upgrade    $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header CF-Connecting-IP  $http_cf_connecting_ip;
    proxy_set_header CF-Ray            $http_cf_ray;

    proxy_connect_timeout {{ nginx_proxy_connect_timeout }};
    proxy_send_timeout    {{ nginx_proxy_read_timeout_ws }};
    proxy_read_timeout    {{ nginx_proxy_read_timeout_ws }};

    # Disable buffering so WS messages flow through immediately.
    proxy_buffering off;
  }
}
