# {{ ansible_managed }}
# Trust Cloudflare's edge IPs and use CF-Connecting-IP as the real client IP.
# Without this, every request looks like it came from Cloudflare and our logs
# / rate limits / fail2ban would target Cloudflare's network instead of the
# actual visitor.

{% for cidr in nginx_cloudflare_ipv4 %}
set_real_ip_from {{ cidr }};
{% endfor %}
{% for cidr in nginx_cloudflare_ipv6 %}
set_real_ip_from {{ cidr }};
{% endfor %}

real_ip_header CF-Connecting-IP;
real_ip_recursive on;
