# {{ ansible_managed }}
# api.balruno.com — Spring Boot reverse proxy.
# 80 redirects to 443 for any direct hits; Cloudflare always sends HTTPS.

server {
  listen 80;
  listen [::]:80;
  server_name {{ api_domain }};

  # Cloudflare always-use-https takes care of this for browsers, but origin-
  # direct probes (or future curl tests) get redirected here.
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name {{ api_domain }};

  ssl_certificate     {{ nginx_origin_cert_path }};
  ssl_certificate_key {{ nginx_origin_key_path }};
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers on;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:10m;

  client_max_body_size {{ nginx_client_max_body_size }};
  keepalive_timeout    {{ nginx_keepalive_timeout }};

  # Optional: only accept traffic that came through Cloudflare. Reject
  # anything else with 403. Belt + suspenders alongside OCI Security List.
  if ($http_cf_connecting_ip = "") {
    return 403;
  }

  location / {
    proxy_pass http://{{ nginx_backend_spring_host }}:{{ nginx_backend_spring_port }};
    proxy_http_version 1.1;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host  $host;
    proxy_set_header CF-Connecting-IP  $http_cf_connecting_ip;
    proxy_set_header CF-Ray            $http_cf_ray;

    proxy_connect_timeout {{ nginx_proxy_connect_timeout }};
    proxy_send_timeout    {{ nginx_proxy_send_timeout }};
    proxy_read_timeout    {{ nginx_proxy_read_timeout }};

    # WebSocket upgrade — Spring Boot serves /ws/projects/{id} per ADR 0008.
    # $connection_upgrade map is defined in 00-maps.conf (loaded first).
    proxy_set_header Upgrade    $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
  }

  # Spring Boot Actuator — only allow Cloudflare-routed requests AND require
  # a future internal token (Phase B-7). For now the rule above already
  # blocks non-CF traffic, so /actuator works through the same gate.
  location /actuator/health {
    proxy_pass http://{{ nginx_backend_spring_host }}:{{ nginx_backend_spring_port }}/actuator/health;
    proxy_set_header Host $host;
    access_log off;
  }
}
