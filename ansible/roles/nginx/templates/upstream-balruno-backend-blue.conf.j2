# {{ ansible_managed }}
# ADR 0044 — Balruno backend (Spring) upstream snippet, BLUE active.
#
# When this file is the symlink target of conf.d/balruno-backend-active.conf,
# nginx routes traffic to the blue container ({{ backend_blue_host_port }}).
# Green is listed as 'backup' so it only takes traffic if blue dies.

upstream balruno_backend {
  server 127.0.0.1:{{ backend_blue_host_port }};
  server 127.0.0.1:{{ backend_green_host_port }} backup;
}
