# {{ ansible_managed }}
# /opt/balruno/collab/.env — loaded by docker-compose via env_file.
#
# Mode 0640 root:docker (rendered by tasks/main.yml). The docker daemon
# (root) reads this to start the container; rocky never sees plaintext
# unless they docker exec into the container themselves.
#
# Secrets originate in group_vars/all/vault.yml and only land here at
# Ansible-render time on prod_app. Never copied to repo.

# ─── Postgres (same instance the backend uses) ─────────────────────────
POSTGRES_HOST={{ hocuspocus_postgres_host }}
POSTGRES_PORT={{ hocuspocus_postgres_port }}
POSTGRES_DB={{ hocuspocus_postgres_db }}
POSTGRES_USER={{ hocuspocus_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}

# ─── Collab token verification (RS256, ADR 0002 v1.2) ──────────────────
# Public half of the RSA key pair the Spring backend signs with. Private
# key never leaves Spring — a leak of this PEM does NOT let an attacker
# forge tokens. Rotation: regenerate vault_jwt_rsa_{private,public}_key,
# re-run ansible-deploy on backend + hocuspocus together, bounce both.
# Active sessions reconnect with fresh tokens from the backend.
COLLAB_TOKEN_PUBLIC_KEY={{ vault_jwt_rsa_public_key }}

# ─── Listen port — nginx upstream points at this ───────────────────────
COLLAB_PORT={{ hocuspocus_collab_port }}

# ─── Internal HTTP channel — Spring backend → side-car ─────────────────
# POST /internal/snapshot/:docId for force-snapshot before doc duplicate.
# Bound to 127.0.0.1 inside the container; docker maps the host port
# (1245) so the backend container can reach it via host.docker.internal.
# Empty COLLAB_INTERNAL_SECRET disables the endpoint (returns 401), which
# is the safe default until the secret is rendered from vault.yml.
COLLAB_INTERNAL_PORT={{ hocuspocus_internal_container_port }}
COLLAB_INTERNAL_SECRET={{ vault_collab_internal_secret }}
