# {{ ansible_managed }}
# Production compose for the Balruno collab (Hocuspocus) server on prod_app.
# Image is built + pushed to GHCR by .github/workflows/collab-deploy.yml.
#
# Blue/green deploy — ADR 0044. Both colors are defined here, but each is
# gated behind a Compose profile so that `docker compose up -d` (with no
# profile) starts nothing. The deploy workflow is the only entrypoint and
# selects exactly one color via COMPOSE_PROFILES=<blue|green>.
#
# Hocuspocus listens on {{ hocuspocus_container_port }} inside both
# containers; only the host-side mapping differs. nginx routes to whichever
# host port is "active" via a snippet symlink swap (see nginx role).

name: balruno-collab

services:
  collab-blue:
    profiles: [blue]
    image: {{ hocuspocus_image_repo }}:{{ hocuspocus_image_tag }}
    container_name: balruno-collab-blue
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ hocuspocus_blue_host_port }}:{{ hocuspocus_container_port }}"
    env_file:
      - {{ hocuspocus_env_file }}
    mem_limit: {{ hocuspocus_container_mem_limit }}
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://127.0.0.1:{{ hocuspocus_container_port }}/', r => process.exit([200, 426].includes(r.statusCode) ? 0 : 1)).on('error', () => process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s

  collab-green:
    profiles: [green]
    image: {{ hocuspocus_image_repo }}:{{ hocuspocus_image_tag }}
    container_name: balruno-collab-green
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ hocuspocus_green_host_port }}:{{ hocuspocus_container_port }}"
    env_file:
      - {{ hocuspocus_env_file }}
    mem_limit: {{ hocuspocus_container_mem_limit }}
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://127.0.0.1:{{ hocuspocus_container_port }}/', r => process.exit([200, 426].includes(r.statusCode) ? 0 : 1)).on('error', () => process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
