#!/usr/bin/env bash
# {{ ansible_managed }}
# Balruno offsite backup uploader.
# Reads the newest pg_dump from {{ osu_source_dir }} (same host, written by
# the backup role's nightly dump cron), uploads it to Cloudflare R2.
# Run by cron as the {{ osu_user }} user.

set -euo pipefail

# cron's spawned shell may inherit a cwd this user cannot read (e.g. /root).
cd "{{ osu_home }}"

SOURCE_DIR="{{ osu_source_dir }}"
STAGING="{{ osu_staging_dir }}"
BUCKET="{{ osu_r2_bucket }}"
ENDPOINT="{{ osu_r2_endpoint }}"
PREFIX="{{ osu_r2_prefix }}"
TODAY="$(date -u +%Y-%m-%d)"
LOG_PREFIX="[$(date -u +%FT%TZ) balruno-upload]"

log() { echo "$LOG_PREFIX $*"; }
fail() { log "ERROR: $*"; exit 1; }

log "starting daily upload run for $TODAY"

# 1. Find the newest .sql.gz in the local backup dir. The backup role's
#    dump cron deposits files here; we read them in-place — no copy,
#    no SSH.
LATEST="$(ls -1t "$SOURCE_DIR"/*.sql.gz 2>/dev/null | head -1 || true)"
[ -n "$LATEST" ] || fail "no .sql.gz found in $SOURCE_DIR"

log "latest dump: $(basename "$LATEST") ($(du -h "$LATEST" | cut -f1))"

# 2. Upload to R2. Path-style + auto region — R2's S3 API quirks are handled
#    via ~/.aws/config (addressing_style=virtual, region=auto).
KEY="$PREFIX/$TODAY/$(basename "$LATEST")"
/usr/local/bin/aws s3 cp "$LATEST" "s3://$BUCKET/$KEY" \
  --endpoint-url "$ENDPOINT" \
  --no-progress \
  || fail "/usr/local/bin/aws s3 cp failed"

log "uploaded -> s3://$BUCKET/$KEY"

# 3. Verify the object actually exists on R2 (defence in depth — cp can return 0
#    even when the SDK retries silently in some failure modes).
/usr/local/bin/aws s3api head-object --bucket "$BUCKET" --key "$KEY" --endpoint-url "$ENDPOINT" \
  > /dev/null 2>&1 \
  || fail "head-object verification failed for $KEY"

log "verified -> s3://$BUCKET/$KEY"

# 4. (No staging cleanup needed — we read from the canonical SOURCE_DIR
#    in-place; the backup role's retention cron handles old files.)
mkdir -p "$STAGING"
log "done"
