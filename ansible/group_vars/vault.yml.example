# vault.yml 예시 — 실제 사용 시 ansible-vault encrypt
#
# 작성 후:
#   ansible-vault encrypt group_vars/vault.yml
#
# 편집:
#   ansible-vault edit group_vars/vault.yml --vault-password-file ~/.ssh/.vault_pass
#
# 진짜 vault.yml 은 .gitignore (이미 docs/backend 가 ignore 됨, ansible/ 도 .gitignore 추가)

# PostgreSQL
vault_postgres_password: "REPLACE_WITH_RANDOM_32_CHAR"
vault_postgres_replication_password: "REPLACE_WITH_RANDOM_32_CHAR"

# Spring Boot
vault_jwt_secret: "REPLACE_WITH_HMAC_HS256_KEY_32_BYTES_BASE64"
vault_jwt_collab_secret: "REPLACE_WITH_DIFFERENT_HS256_KEY"  # collab token 별도 (ADR 0002 v1.1)

# OAuth (GitHub + Google)
vault_github_oauth_client_id: ""
vault_github_oauth_client_secret: ""
vault_google_oauth_client_id: ""
vault_google_oauth_client_secret: ""

# Grafana
vault_grafana_admin_password: "REPLACE_WITH_RANDOM_32_CHAR"

# InfluxDB 2.x
vault_influxdb_admin_token: "REPLACE_WITH_RANDOM_64_CHAR"
vault_influxdb_org: "balruno"
vault_influxdb_bucket_k6: "k6"

# Cloudflare Tunnel (monitor.balruno.com)
vault_cloudflare_tunnel_token: "REPLACE_WITH_TUNNEL_TOKEN"
# Cloudflare Access GitHub OAuth allowlist
vault_cloudflare_access_allowed_emails:
  - "dj258255@naver.com"

# Cloudflare API (DNS 자동 갱신용, 선택)
vault_cloudflare_api_token: "REPLACE_IF_USING_DDNS_OR_AUTO_DNS"

# OCI CLI (Object Storage upload daemon)
vault_oci_user_ocid: "ocid1.user.oc1..."
vault_oci_tenancy_ocid: "ocid1.tenancy.oc1..."
vault_oci_fingerprint: "aa:bb:cc:dd:..."
vault_oci_private_key_path: "~/.oci/oci_api_key.pem"

# Uptime Kuma admin (첫 셋업 시 web UI 에서 직접 생성, vault 보관)
vault_uptime_kuma_admin_password: "REPLACE_WITH_RANDOM_32_CHAR"

# Sentry (frontend 와 같은 DSN 또는 별도)
vault_sentry_dsn_backend: ""

# Anthropic (AI 프록시, FR-AI v1)
vault_anthropic_api_key: ""
