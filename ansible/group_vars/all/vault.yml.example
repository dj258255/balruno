# Template for group_vars/vault.yml — encrypt with ansible-vault before use.
#
# First-time setup:
#   cp group_vars/vault.yml.example group_vars/vault.yml
#   # fill in real secrets, then encrypt in place:
#   ansible-vault encrypt group_vars/vault.yml
#
# Edit later:
#   ansible-vault edit group_vars/vault.yml
#
# The encrypted vault.yml is committed to the repo. The plaintext password
# that decrypts it lives in $ANSIBLE_VAULT_PASSWORD_FILE locally and in the
# ANSIBLE_VAULT_PASSWORD GitHub Secret in CI.

# PostgreSQL
vault_postgres_password: "REPLACE_WITH_RANDOM_32_CHAR"
vault_postgres_replication_password: "REPLACE_WITH_RANDOM_32_CHAR"

# Spring Boot — RSA key pair for RS256 JWT signing (ADR 0002 v1.2).
# Same key pair signs main API JWTs (aud=balruno-api) and collab JWTs
# (aud=balruno-collab); Hocuspocus only gets the public half.
#
# Generate (private — PKCS#8, public — X.509 SPKI):
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -outform PEM > priv.pem
#   openssl rsa -in priv.pem -pubout -outform PEM > pub.pem
#
# Then paste each full PEM block (including its `-----BEGIN ... KEY-----` and
# `-----END ... KEY-----` lines) as a YAML literal block — see below.
# Empty strings here are intentional: this is a template, not a real vault.
# The values must be populated before ansible-deploy. The Spring backend's
# PemKeys parser fails fast on a missing or malformed key.
vault_jwt_rsa_private_key: ""
vault_jwt_rsa_public_key: ""

# Force-snapshot internal channel — backend → Hocuspocus side-car
# (POST /internal/snapshot/:docId before doc duplicate). Both the
# backend container and the collab container read this same value;
# mismatch = 401 from the side-car + best-effort fall back to the
# last persisted ydoc_state.
# Generate via: openssl rand -hex 32
vault_collab_internal_secret: "REPLACE_WITH_OPENSSL_RAND_HEX_32"

# OAuth (GitHub + Google)
vault_github_oauth_client_id: ""
vault_github_oauth_client_secret: ""
vault_google_oauth_client_id: ""
vault_google_oauth_client_secret: ""

# Grafana
vault_grafana_admin_password: "REPLACE_WITH_RANDOM_32_CHAR"

# InfluxDB 2.x
vault_influxdb_admin_token: "REPLACE_WITH_RANDOM_64_CHAR"
vault_influxdb_admin_password: "REPLACE_WITH_RANDOM_32_CHAR"
vault_influxdb_org: "balruno"
vault_influxdb_bucket_k6: "k6"

# Cloudflare Tunnel (monitor.balruno.com)
vault_cloudflare_tunnel_token: "REPLACE_WITH_TUNNEL_TOKEN"
# Cloudflare Access GitHub OAuth allowlist
vault_cloudflare_access_allowed_emails:
  - "REPLACE_WITH_OPERATOR_EMAIL"

# Cloudflare API (optional — used for DNS automation only)
vault_cloudflare_api_token: "REPLACE_IF_USING_DDNS_OR_AUTO_DNS"

# Cloudflare R2 — backup offsite (S3-compatible). ADR 0007 v1.2.
# Generate via: Cloudflare dashboard → R2 → Manage R2 API Tokens → Create.
# Permissions: Object Read & Write, scoped to balruno-backup bucket.
vault_r2_access_key_id: "REPLACE_WITH_R2_ACCESS_KEY_ID"
vault_r2_secret_access_key: "REPLACE_WITH_R2_SECRET_ACCESS_KEY"

# Cloudflare Origin Certificate (15-year, *.balruno.com + balruno.com).
# Generate via: Cloudflare → SSL/TLS → Origin Server → Create Certificate.
# Used by nginx role on prod_app for Full (Strict) TLS with Cloudflare edge.
vault_cloudflare_origin_cert: |
  -----BEGIN CERTIFICATE-----
  REPLACE_WITH_CLOUDFLARE_ORIGIN_CERT_CONTENT
  -----END CERTIFICATE-----
vault_cloudflare_origin_key: |
  -----BEGIN PRIVATE KEY-----
  REPLACE_WITH_CLOUDFLARE_ORIGIN_KEY_CONTENT
  -----END PRIVATE KEY-----

# Sentry (same DSN as frontend or a separate one)
vault_sentry_dsn_backend: ""

# Discord webhook for Grafana Alertmanager — #alerts channel.
# Generate via: Discord channel → Edit channel → Integrations → Webhooks.
vault_discord_webhook_url: "REPLACE_WITH_DISCORD_WEBHOOK_URL"

# Anthropic API (FR-AI v1 — used by the in-app AI proxy)
vault_anthropic_api_key: ""

# Actuator internal-token gate (ADR 0045 / Phase B-7).
# Optional. When defined and non-empty, /actuator/* on api.balruno.com
# requires an `X-Internal-Token` header matching this value. nginx
# (api.conf.j2), the monitor blackbox_exporter (blackbox-config.yml.j2),
# and the GitHub Actions backend-deploy smoke test all read this same
# value (the workflow uses it via the ACTUATOR_INTERNAL_TOKEN repo
# secret — keep both in sync).
#
# Generate via: openssl rand -hex 32
# Leave commented out to keep the gate inactive (graceful default).
# vault_actuator_internal_token: "REPLACE_WITH_OPENSSL_RAND_HEX_32"
